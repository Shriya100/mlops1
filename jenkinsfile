pipeline {
    agent any

    stages {
        stage('Setup') {
            steps {
                echo 'Installing dependencies...'
                bat '"C:\\Users\\win10\\AppData\\Local\\Programs\\Python\\Python313\\python.exe" --version'
                bat '"C:\\Users\\win10\\AppData\\Local\\Programs\\Python\\Python313\\python.exe" -m pip install --upgrade pip'
                bat '"C:\\Users\\win10\\AppData\\Local\\Programs\\Python\\Python313\\python.exe" -m pip install -r requirements.txt'
            }
        }

        stage('Build & Test') {
            steps {
                echo 'Running ML pipeline...'
                bat '"C:\\Users\\win10\\AppData\\Local\\Programs\\Python\\Python313\\python.exe" ml_pipeline.py'
            }
        }
    }

    post {
        success {
            echo 'Pipeline SUCCESS - Model validated'
        }
        failure {
            echo 'Pipeline FAILED - Check logs'
        }
    }
}
